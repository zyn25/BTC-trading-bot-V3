# ========== ENVIRONMENT ==========
ENV=development
DEBUG=false
TESTNET=true

# ========== EXCHANGE ==========
EXCHANGE_NAME=binance
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_SECRET=your_secret_here
EXCHANGE_PASSPHRASE=

# ========== TELEGRAM ==========
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_IDS=123456789,987654321
TELEGRAM_CHANNEL_ID=
LOG_CHAT_ID=

# ========== TRADING ==========
SYMBOL=BTC/USDT
TIMEFRAME=15m
TIMEFRAMES_HIGHER=1h,4h
LEVERAGE=5

# Position Sizing
MAX_POSITION_PCT=0.10
RISK_PER_TRADE=0.01
MAX_OPEN_TRADES=2
MAX_DAILY_TRADES=10
MAX_DAILY_LOSS_PCT=0.03
MAX_DRAWDOWN_PCT=0.15

# SL/TP
STOP_LOSS_ATR_MULT=1.5
TAKE_PROFIT_ATR_MULT=2.5
TRAILING_STOP_PCT=0.015
TRAILING_ACTIVATION_PCT=0.02
MIN_RISK_REWARD=1.8

# ========== AI - HYBRID SYSTEM ==========
# AI_MODE: technical (no Groq) | hybrid (with Groq - recommended)
AI_MODE=hybrid

# Groq API (FREE - https://console.groq.com/)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# Fear & Greed Index (FREE - no key needed)
AI_USE_SENTIMENT_FNG=true
FNG_API_URL=https://api.alternative.me/fng/

# CryptoPanic News (Optional - register at cryptopanic.com)
CRYPTOPANIC_API_KEY=
USE_NEWS_API=false

# ========== DATABASE ==========
DATABASE_URL=sqlite+aiosqlite:///data/trading_bot.db

# ========== NOTIFICATIONS ==========
NOTIFY_ENABLED=true
NOTIFY_ON_TRADE=true
NOTIFY_ON_SIGNAL=true
NOTIFY_ON_ERROR=true
NOTIFY_ON_DAILY_SUMMARY=true

# ========== MONITORING ==========
HEALTH_CHECK_INTERVAL=300
POSITION_CHECK_INTERVAL=10
SCAN_INTERVAL=60
